oc() {
    local base_name=$(basename "$PWD")
    local path_hash=$(echo "$PWD" | md5sum | cut -c1-4)

    # Find available port
    local port=4096
    while [ $port -lt 5096 ]; do
        if ! lsof -i :$port >/dev/null 2>&1; then
            break
        fi
        port=$((port + 1))
    done

    local session_name="${base_name}-${path_hash}-${port}-$$-$(date +%Y%m%d%H%M%S)-$RANDOM"

    export OPENCODE_PORT=$port

    if [ -n "$TMUX" ]; then
        opencode --port $port "$@"
    else
        local -a oc_cmd=(env OPENCODE_PORT="$port" opencode --port "$port")
        if [ $# -gt 0 ]; then
            oc_cmd+=("$@")
        fi

        tmux new-session -s "$session_name" -c "$PWD" "${oc_cmd[@]}"
    fi
}
