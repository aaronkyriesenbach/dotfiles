{
  "hideThinkingBlock": true,
  "lastChangelogVersion": "0.80.6",
  "theme": "dark",
  "shellPath": "~/.local/bin/agent-shell-sandbox",
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-sonnet-5",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-web-access",
    "npm:context-mode",
    "npm:pi-mcp-adapter",
    "npm:pi-subagents",
    {
      "source": "npm:@juicesharp/rpiv-todo",
      "extensions": [
        "+index.ts"
      ]
    },
    "npm:pi-lens",
    "git:github.com/aaronkyriesenbach/pi-package-manager@master",
    "npm:@aaronkyriesenbach/pi-frozen-defaults@0.2.1"
  ],
  "subagents": {
    "agentOverrides": {
      "researcher": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "normal",
        "output": false
      },
      "scout": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "normal",
        "output": false
      },
      "delegate": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "normal"
      },
      "context-builder": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "normal"
      },
      "planner": {
        "model": "openrouter/deepseek/deepseek-v4-pro",
        "thinking": "high",
        "output": false
      },
      "worker": {
        "model": "openrouter/deepseek/deepseek-v4-pro",
        "thinking": "high"
      },
      "reviewer": {
        "model": "openrouter/deepseek/deepseek-v4-pro",
        "thinking": "high"
      },
      "oracle": {
        "model": "openrouter/deepseek/deepseek-v4-pro",
        "thinking": "high"
      }
    }
  }
}