{
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf /*": "ask",
      "find /*": "deny",
      "find ~/": "allow"
    },
    "external_directory": {
	"*": "ask",
	"~/*": "allow",
	"/tmp/*": "allow",
	"/private/tmp/*": "allow",
	"/dev/null": "allow"
    }
  }
}
