{
    "layer": "top",
    "position": "bottom",
    "modules-left": ["sway/workspaces", "sway/mode", "hyprland/workspaces"],
    "modules-center": ["mpris"],
    "modules-right": ["cpu", "memory", "clock", "battery", "tray"],
    "sway/workspaces": {
        "enable-bar-scroll": true
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "format": "{:%D %H:%M}",
        "tooltip": "false",
    },
    "cpu": {
        "format": "cpu: {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ram: {}%"
    },
    "battery": {
        "format-charging": "{capacity}% ⏚"
    },
    "tray": {
        "spacing": 0
    },
    "mpris": {
        "format": "{status_icon} {artist} - {title}",
        "status-icons": {
            "playing": "▶",
            "paused": "⏸"
        }
    }
}
