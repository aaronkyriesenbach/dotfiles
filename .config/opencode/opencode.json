{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "$HOME/.config/opencode/*": "allow",
      "$HOME/.cache/*": "allow",
      "/tmp/*": "allow",
      "/var/folders/t9/*": "allow"
    },
    "compress": "allow"
  },
  "plugin": [
    "oh-my-openagent",
    "opencode-antigravity-auth@1.6.0"
  ]
}
