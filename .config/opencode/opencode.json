{
  "$schema": "https://opencode.ai/config.json",
  "shell": "{env:HOME}/.local/bin/agent-shell-sandbox",
  "permission": {
    "external_directory": {
      "$HOME/.config/opencode/*": "allow",
      "$HOME/.cache/*": "allow",
      "/tmp/*": "allow",
      "/var/folders/t9/*": "allow"
    },
    "compress": "allow"
  },
  "plugin": ["opencode-antigravity-auth@1.6.0", "oh-my-openagent@latest"],
  "formatter": true
}
