[include]
	path = .gitidentity

[includeIf "gitdir/i:/Users/Aaron/Repos/personal-projects/"]
	path = /Users/Aaron/Repos/personal-projects/.gitconfig

[push]
	default = simple

[pull]
	rebase = true

[log]
	decorate = true
	abbrevCommit = true

[pager]
	branch = false

[merge]
	tool = nvimdiff

[init]
	defaultBranch = master
