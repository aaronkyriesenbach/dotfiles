[include]
	path = .gitidentity

[includeIf "gitdir/i:/Users/Aaron/Repos/personal-projects/"]
	path = /Users/Aaron/Repos/personal-projects/.gitconfig

[push]
	default = simple

[pull]
	rebase = true

[log]
	decorate = true
	abbrevCommit = true

[pager]
	branch = false

[merge]
	tool = nvimdiff

[init]
	defaultBranch = master
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
